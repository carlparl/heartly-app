DJANGO_ENV=production
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=replace-with-real-secret-key
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
DJANGO_CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

DATABASE_URL=postgres://user:password@host:5432/dbname

CHANNEL_LAYER_BACKEND=channels_redis.core.RedisChannelLayer
REDIS_URL=redis://your-redis-url

MEDIA_STORAGE_BACKEND=s3
AWS_ACCESS_KEY_ID=replace-with-access-key
AWS_SECRET_ACCESS_KEY=replace-with-secret-key
AWS_STORAGE_BUCKET_NAME=replace-with-bucket-name
AWS_S3_REGION_NAME=replace-with-region
AWS_S3_ENDPOINT_URL=
AWS_S3_CUSTOM_DOMAIN=
AWS_QUERYSTRING_AUTH=False

GROQ_API_KEY=replace-with-real-groq-key
GROQ_MODEL=openai/gpt-oss-20b

DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_USE_X_FORWARDED_PROTO=True
DJANGO_SECURE_HSTS_SECONDS=3600
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=False
DJANGO_SECURE_HSTS_PRELOAD=False
